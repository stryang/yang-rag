# ===========================================
# Yang RAG System - 环境配置示例
# ===========================================
# 复制此文件为 .env 并填入您的配置
# ===========================================

# ========== LLM 配置 ==========
# 提供商选项: openai, siliconflow, qwen, ollama

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-openai-api-key
# LLM_BASE_URL=  # 可选，用于代理或自定义端点
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ========== Embedding 配置 ==========
# 提供商选项: openai, siliconflow, huggingface, ollama

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-your-openai-api-key
# EMBEDDING_BASE_URL=  # 可选
EMBEDDING_DIMENSION=1536

# ========== 向量存储 ==========
# 向量存储类型: chroma, faiss, milvus

VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PERSIST_DIR=./data/vectorstore

# ChromaDB 配置
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Milvus 配置 (可选)
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION=yang_rag

# ========== API 配置 ==========
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=rag-secret-key

# ========== MCP 服务 ==========
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# ========== 检索设置 ==========
RETRIEVAL_TOP_K=5
RERANK_TOP_K=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ========== CORS ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== 支持的文件类型 ==========
SUPPORTED_FILE_TYPES=.pdf,.docx,.doc,.txt,.md,.html,.pptx,.xlsx
